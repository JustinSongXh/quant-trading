.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.update-time {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.table-header {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.table-row:active {
  background: #f0f7ff;
}

.col-name {
  flex: 2.5;
  display: flex;
  flex-direction: column;
}

.stock-name {
  font-size: 28rpx;
  color: #333;
}

.stock-code {
  font-size: 22rpx;
  color: #999;
}

.col-price {
  flex: 1.5;
  text-align: right;
  font-size: 26rpx;
}

.col-signal {
  flex: 1.2;
  text-align: right;
  font-size: 26rpx;
}

.col-rec {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
}

.col-pos {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
}

.tip {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #ccc;
}
