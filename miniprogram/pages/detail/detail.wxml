<view class="container">
  <view wx:if="{{loading}}" class="loading"><text>正在分析...</text></view>
  <view wx:if="{{error}}" class="card" style="text-align:center;color:#e74c3c"><text>{{error}}</text></view>

  <block wx:if="{{info && !loading}}">
    <!-- 综合推荐 -->
    <view class="card rec-card">
      <view class="rec-header">
        <text class="rec-date">{{info.date}}</text>
        <text class="rec-close">收盘 {{info.close}}</text>
      </view>
      <view class="rec-main">
        <text class="rec-text" style="color:{{info.recommendation === '买入' ? '#e74c3c' : info.recommendation === '卖出' ? '#27ae60' : '#999'}}">
          {{info.recommendation}}
        </text>
        <view class="rec-detail" wx:if="{{info.position}}">
          <text class="rec-label">仓位建议</text>
          <text class="rec-value" style="color:{{info.recommendation === '买入' ? '#e74c3c' : '#27ae60'}}">{{info.position}}</text>
        </view>
        <view class="rec-detail">
          <text class="rec-label">信号强度</text>
          <text class="rec-value">{{info.strength}}</text>
        </view>
      </view>
    </view>

    <!-- 策略明细 -->
    <view class="card">
      <view class="section-title">策略分析</view>
      <view class="strategy-grid">
        <view class="strategy-item">
          <text class="strategy-name">MACD</text>
          <text class="strategy-verdict" style="color:{{info.strategies.macd.verdict === '多头' ? '#e74c3c' : '#27ae60'}}">{{info.strategies.macd.verdict}}</text>
          <text class="strategy-sub">DIF {{info.strategies.macd.dif}}</text>
        </view>
        <view class="strategy-item">
          <text class="strategy-name">RSI</text>
          <text class="strategy-verdict">{{info.strategies.rsi.value}}</text>
          <text class="strategy-sub">{{info.strategies.rsi.verdict}}</text>
        </view>
        <view class="strategy-item">
          <text class="strategy-name">SuperTrend</text>
          <text class="strategy-verdict" style="color:{{info.strategies.supertrend.direction === '多头' ? '#e74c3c' : '#27ae60'}}">{{info.strategies.supertrend.direction}}</text>
          <text class="strategy-sub">轨道 {{info.strategies.supertrend.value}}</text>
        </view>
        <view class="strategy-item">
          <text class="strategy-name">缠论</text>
          <text class="strategy-verdict">{{info.strategies.chanlun.bi_count}}笔 {{info.strategies.chanlun.zs_count}}中枢</text>
          <text class="strategy-sub">{{info.strategies.chanlun.buy_count}}买 {{info.strategies.chanlun.sell_count}}卖</text>
        </view>
      </view>

      <view class="signal-bar">
        <text>技术信号: <text style="color:{{info.technical_signal > 0 ? '#e74c3c' : info.technical_signal < 0 ? '#27ae60' : '#999'}};font-weight:bold">{{info.technical_signal}}</text></text>
        <text style="margin-left:30rpx">缠论信号: <text style="color:{{info.chanlun_signal > 0 ? '#e74c3c' : info.chanlun_signal < 0 ? '#27ae60' : '#999'}};font-weight:bold">{{info.chanlun_signal}}</text></text>
      </view>
    </view>

    <!-- K线图 -->
    <view class="card">
      <view class="section-title">K线走势</view>
      <view class="chart-wrap">
        <ec-canvas id="klineCanvas" canvas-id="klineCanvas" ec="{{ecKline}}"></ec-canvas>
      </view>
    </view>

    <!-- 缠论买卖点 -->
    <view class="card" wx:if="{{info.chan_points.length > 0}}">
      <view class="section-title">缠论买卖点</view>
      <view class="chan-list">
        <view class="chan-item" wx:for="{{info.chan_points}}" wx:key="index">
          <text class="chan-type" style="color:{{item.direction === '买' ? '#e74c3c' : '#27ae60'}}">{{item.type}}</text>
          <text class="chan-dir" style="color:{{item.direction === '买' ? '#e74c3c' : '#27ae60'}}">{{item.direction}}</text>
          <text class="chan-price">{{item.price}}</text>
          <text class="chan-date">{{item.date}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
