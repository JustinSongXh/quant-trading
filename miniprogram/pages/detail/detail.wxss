.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* 推荐卡片 */
.rec-card {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
}

.rec-header {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
}

.rec-main {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.rec-text {
  font-size: 56rpx;
  font-weight: bold;
}

.rec-detail {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rec-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.rec-value {
  font-size: 30rpx;
  font-weight: bold;
}

/* 策略网格 */
.strategy-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.strategy-item {
  flex: 1;
  min-width: 140rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.strategy-name {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.strategy-verdict {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.strategy-sub {
  font-size: 20rpx;
  color: #999;
}

.signal-bar {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #666;
}

/* K线图 */
.chart-wrap {
  width: 100%;
  height: 500rpx;
}

#klineCanvas {
  width: 100%;
  height: 100%;
}

/* 缠论买卖点 */
.chan-list {
  font-size: 26rpx;
}

.chan-item {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.chan-type {
  flex: 1;
  font-weight: bold;
}

.chan-dir {
  flex: 1;
  text-align: center;
}

.chan-price {
  flex: 1.5;
  text-align: right;
}

.chan-date {
  flex: 2;
  text-align: right;
  color: #999;
}
